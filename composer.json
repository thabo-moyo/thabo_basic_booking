{
    "name": "panther/booking-platform",
    "description": "A simple booking platform built with Slim 4 and Eloquent",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "illuminate/database": "^11.0",
        "illuminate/pagination": "^11.0",
        "illuminate/events": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "db:setup": "php database/setup.php",
        "serve": "php -S localhost:8080 -t public"
    }
}
